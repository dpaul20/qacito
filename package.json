{
  "name": "qacito",
  "version": "0.1.0",
  "description": "Local MCP-based QA platform powered by Playwright. AI-free server — Claude Desktop orchestrates.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-public.js",
    "build:dashboard": "cd dashboard && npm install && npx vite build",
    "build:all": "npm run build:dashboard && npm run build",
    "start": "node dist/server/index.js",
    "start:http": "QACITO_HTTP_PORT=4712 node dist/server/index.js",
    "build:mcpb": "npm run build:all && node scripts/build-mcpb.js",
    "pack:mcpb": "npx @anthropic-ai/mcpb pack",
    "sign:mcpb": "npx @anthropic-ai/mcpb sign qacito.mcpb",
    "test": "npx playwright test --reporter=json",
    "batch": "node dist/batch/index.js",
    "install-hooks": "sh scripts/install-hooks.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "hono": ">=4.12.25",
    "fast-uri": ">=3.1.2",
    "form-data": ">=4.0.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.0",
    "@clack/prompts": "^0.9.0",
    "@playwright/test": "^1.47.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "axe-core": "^4.9.0",
    "js-yaml": "^4.1.0",
    "typescript": "^6.0.3"
  }
}
